parameters:
    level: 9
    disableMigrationScan: true
    paths:
        - app
        - routes
        - tests
    excludePaths:
        - routes/console.php
    ignoreErrors:
        - '#has parameter \$[a-z]+ with generic class Illuminate\\Testing\\TestResponse but does not specify its types#'
        - '#return type with generic class Illuminate\\Testing\\TestResponse does not specify its types#'
        - '#missingType\.iterableValue#'
    reportUnmatchedIgnoredErrors: false
