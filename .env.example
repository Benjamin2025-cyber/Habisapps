APP_NAME=habis-finance-api
APP_ENV=local
APP_KEY=

# Production: APP_DEBUG must be false and APP_ENV should be production.
APP_DEBUG=true
APP_URL=http://localhost:8000
API_VERSION=1.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=habis_finance_api
DB_USERNAME=postgres
# Production: set a strong, non-empty database password through your secret manager.
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 Media Storage
R2_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
R2_ENDPOINT=
R2_URL=
R2_USE_PATH_STYLE_ENDPOINT=true

# Media Storage Policy
MEDIA_DISK_AUTO=true
MEDIA_R2_FALLBACK_MODE=fail_closed
MEDIA_R2_HEALTH_TIMEOUT_SECONDS=5

DATABASE_MANAGEMENT_ENABLED=true
DATABASE_MANAGEMENT_CONNECTION=pgsql
DATABASE_MANAGEMENT_DISK=local
DATABASE_MANAGEMENT_REMOTE_DISK=
DATABASE_MANAGEMENT_PATH_PREFIX=database-backups
DATABASE_MANAGEMENT_ENCRYPTION_ENABLED=false
DATABASE_MANAGEMENT_ENCRYPTION_KEY=
DATABASE_MANAGEMENT_COMPRESSION=gzip
DATABASE_MANAGEMENT_RETENTION_MAX_AGE_DAYS=30
DATABASE_MANAGEMENT_RETENTION_MAX_COUNT=30
DATABASE_MANAGEMENT_RETENTION_MIN_PROTECTED=3
DATABASE_MANAGEMENT_RETENTION_KEEP_LAST_VERIFIED=true
DATABASE_MANAGEMENT_MAX_ARTIFACT_BYTES=5368709120
DATABASE_MANAGEMENT_PG_DUMP=pg_dump
DATABASE_MANAGEMENT_PG_RESTORE=pg_restore
DATABASE_MANAGEMENT_PSQL=psql
DATABASE_MANAGEMENT_RUN_SYNC=true
DATABASE_MANAGEMENT_STRICT_VERIFICATION=false
DATABASE_MANAGEMENT_DOWNLOAD_TTL_MINUTES=5
DATABASE_MANAGEMENT_LOCK_TTL_MINUTES=30

DATABASE_RESTORE_ENABLED=true
DATABASE_RESTORE_ALLOW_SAME_DB_IN_PRODUCTION=false
DATABASE_RESTORE_REQUIRE_PRE_BACKUP=true
DATABASE_RESTORE_REQUIRE_CONFIRMATION_PHRASE=false
DATABASE_RESTORE_CONFIRMATION_PHRASE="RESTORE PRODUCTION DATABASE"
DATABASE_RESTORE_PLAN_TTL_MINUTES=15

AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_DECAY_MINUTES=1
AUTH_REGISTER_MAX_ATTEMPTS=3
AUTH_REGISTER_DECAY_MINUTES=1
AUTH_ACTIVATION_MAX_ATTEMPTS=5
AUTH_ACTIVATION_DECAY_MINUTES=1
# Production: keep public registration disabled unless onboarding is explicitly designed for it.
AUTH_REGISTRATION_ENABLED=false
AUTH_TOKEN_TTL_MINUTES=1440
SANCTUM_TOKEN_EXPIRATION_MINUTES=1440
IDEMPOTENCY_TTL_MINUTES=1440
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_DECAY_MINUTES=1
OTP_DELIVERY_MAX_ATTEMPTS=3
OTP_REQUIRE_EMAIL_DELIVERY=true
OTP_DELIVERY_PROVIDER=log
OTP_HTTP_SMS_ENDPOINT=
OTP_HTTP_SMS_TOKEN=
OTP_HTTP_SMS_SENDER=HABIS
OTP_HTTP_SMS_TIMEOUT_SECONDS=10
OTP_EMAIL_PROVIDER=mail

SEED_BOOTSTRAP_ADMIN=false
SEED_BOOTSTRAP_ADMIN_EMAIL=
SEED_BOOTSTRAP_ADMIN_PHONE=
SEED_BOOTSTRAP_ADMIN_NAME=
SEED_BOOTSTRAP_ADMIN_PASSWORD=

MONEY_DEFAULT_CURRENCY=XAF
MONEY_DEFAULT_SCALE=2
MONEY_PHYSICAL_CASH_SCALE=0
